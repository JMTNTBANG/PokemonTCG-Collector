                let JSONFormat = {
                    CardID: -1,
                    UserID: -1,
                    CardType: createWindow.document.getElementById("card_type").value,
                    Name: createWindow.document.getElementById("card_name").value,
                    Parent: parseInt(createWindow.document.getElementById("card_parent").value),
                    HP: createWindow.document.getElementById("card_hp").value,
                    Type: createWindow.document.getElementById("card_type").value,
                    DexNo: parseInt(createWindow.document.getElementById("card_dexno").value),
                    Breed: createWindow.document.getElementById("card_breed").value,
                    Height: height,
                    Weight: parseFloat(createWindow.document.getElementById("card_weight").value),
                    Ability: JSON.parse(createWindow.document.getElementById("card_ability").value),
                    Attacks: JSON.parse(createWindow.document.getElementById("card_attacks").value),
                    Weakness: createWindow.document.getElementById("card_weakness").value,
                    Resistance: createWindow.document.getElementById("card_resistance").value,
                    RetreatCost: parseInt(createWindow.document.getElementById("card_retreat_cost").value),
                    Set: createWindow.document.getElementById("card_set").value,
                    SetNumber: parseInt(createWindow.document.getElementById("card_set_number").value),
                    Rarity: createWindow.document.getElementById("card_rarity").value,
                    Print: createWindow.document.getElementById("card_print").value,
                    Lore: createWindow.document.getElementById("card_lore").value
                }
                for (let value in JSONFormat) {
                    if (JSONFormat[value] === "" || JSONFormat[value] === -1) {
                        JSONFormat[value] = undefined;
                    }
                }
                const credentials = { session: JSON.parse(localStorage.getItem('session')), user: JSON.parse(localStorage.getItem('user')) };
                fetch("cards/create", {
                    headers: {
                        "Content-Type": "application/json"
                    },
                    method: "PUT",
                    body: JSON.stringify({session: credentials.session, user: credentials.user, CardData: JSONFormat})
                }).then(res => res.json())
                    .then(data => {
                        document.getElementById("collection_table").innerHTML +=
                            `<tr>
                                <td style="visibility: hidden; border: none"></td>
                                <td>${data.card.CardType}</td>
                                <td>${data.card.Name}</td>
                                <td>${data.card.Type}</td>
                                <td>${data.card.Breed}</td>
                                <td>${data.card.Set}</td>
                                <td>${data.card.SetNumber}</td>
                                <td>${data.card.Print}</td>
                                <td style="visibility: hidden; border: none"></td>
                            </tr>`
                    })
            })
